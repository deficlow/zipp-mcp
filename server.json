{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.zippfeed/zipp",
  "title": "Zipp",
  "description": "Multi-language crypto news with editorial sentiment + importance scoring; cites original publisher.",
  "version": "1.0.2",
  "websiteUrl": "https://zippfeed.com",
  "repository": {
    "url": "https://github.com/deficlow/zipp-mcp",
    "source": "github"
  },
  "icons": [
    {
      "src": "https://zippfeed.com/static/assets/zipp-news-logo.png",
      "mimeType": "image/png",
      "sizes": ["any"]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://zippfeed.com/mcp/"
    }
  ],
  "_meta": {
    "com.zippfeed/zipp": {
      "languages": [
        "en-US", "tr-TR", "es-ES", "ru-RU",
        "pt-PT", "fr-FR", "de-DE", "it-IT"
      ],
      "tools": [
        "search",
        "get_latest",
        "get_breaking",
        "get_featured",
        "get_post",
        "list_categories"
      ],
      "auth": "none",
      "discovery": "https://zippfeed.com/.well-known/mcp.json",
      "smithery": "https://smithery.ai/servers/deficlow/zipp"
    }
  }
}
